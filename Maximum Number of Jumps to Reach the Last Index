int maximumJumps(int* nums, int n, int target) {
    int dp[n];
    dp[0]=0;
    for(int i=1;i<n;i++){
        dp[i]=-1;
    }
    for(int i=1;i<n;i++){
        for(int j=0;j<i;j++){
            if(abs(nums[i]-nums[j])<=target && dp[j]!=-1){
                dp[i]=(dp[i]>=dp[j]+1)?dp[i]:dp[j]+1;
            }
        }
    }
    return dp[n-1];
}
